{
  "manifest_version": 3,
  "name": "MyEdgeStyle",
  "version": "1.0.0",
  "description": "Edge 扩展美化：自定义新标签页（时间、天气、壁纸、毛玻璃）",
  "permissions": [
    "storage",
    "bookmarks",
    "favicon"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "MyEdgeStyle",
    "default_icon": {
      "16": "assets/icons/16.png",
      "48": "assets/icons/48.png",
      "128": "assets/icons/128.png"
    }
  },
  "icons": {
    "16": "assets/icons/16.png",
    "48": "assets/icons/48.png",
    "128": "assets/icons/128.png"
  },
  "options_ui": {
    "page": "src/options/options.html"
  }
}
